{% liquid
  assign max_items = section.settings.max_products | default: 4
  assign collection = section.settings.collection
%}

<div class="flowzen-grid">

  {% if collection and collection.products_count > 0 %}

    {% for product in collection.products limit: max_items %}

      <div class="flowzen-card">

        {% if product.featured_image %}
          <img 
            src="{{ product.featured_image | img_url: '600x' }}" 
            alt="{{ product.title | escape }}"
            class="flowzen-img"
          >
        {% endif %}

        <h3 class="flowzen-title">{{ product.title }}</h3>

        {% assign variant = product.selected_or_first_available_variant %}

        <div class="flowzen-price">
          <span class="price">{{ variant.price | money }}</span>

          {% if variant.compare_at_price > variant.price %}
            <span class="compare">{{ variant.compare_at_price | money }}</span>
          {% endif %}
        </div>

        <form method="post" action="/cart/add">
          <input type="hidden" name="id" value="{{ variant.id }}">
          
          <button 
            type="submit" 
            class="flowzen-btn"
            {% unless variant.available %}disabled{% endunless %}
          >
            {% if variant.available %}
              Ajouter au panier
            {% else %}
              ❌ Rupture de stock
            {% endif %}
          </button>
        </form>

      </div>

    {% endfor %}

  {% else %}

    <p style="text-align:center;">⚠️ Aucune collection</p>

  {% endif %}

</div>

{% schema %}
{
  "name": "Flowzen Produits",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Nombre de produits",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Flowzen Produits"
    }
  ]
}
{% endschema %}

{% stylesheet %}
.flowzen-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

.flowzen-card {
  background: #fff;
  padding: 16px;
  border-radius: 12px;
  text-align: center;
}

.flowzen-img {
  width: 100%;
  border-radius: 8px;
}

.flowzen-title {
  margin: 10px 0;
}

.flowzen-btn {
  width: 100%;
  padding: 10px;
  background: #0077cc;
  color: white;
  border: none;
  border-radius: 6px;
}
{% endstylesheet %}